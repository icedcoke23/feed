# PostgreSQL 数据库配置（本地数据库）
DATABASE_URL=postgresql://username:password@localhost:5432/feedback_db

# AI SDK配置 (coze-coding-dev-sdk)
COZE_API_KEY=your_coze_api_key

# 对象存储配置 (可选，用于文件上传)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=your_region
S3_BUCKET_NAME=your_bucket_name

# 应用配置
NEXT_PUBLIC_APP_URL=http://localhost:5000

# 安全配置
JWT_SECRET=your-jwt-secret-key-change-in-production
ADMIN_DEFAULT_PASSWORD=

# 默认教务老师账号（可选，格式：username:name,username:name）
# DEFAULT_ADMIN_TEACHERS=xinxin:心心,yanzi:燕子
# DEFAULT_ADMIN_PASSWORD=your_default_admin_password

# PDF 页面图片配置（可选，不配置则使用默认素材）
# NEXT_PUBLIC_BG_IMAGE_URL=/images/pdf-bg.png
# NEXT_PUBLIC_LOGO_URL=/images/logo.png
