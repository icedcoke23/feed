# Supabase 数据库配置（两种命名方式均可，COZE_ 前缀优先）
COZE_SUPABASE_URL=your_supabase_url
COZE_SUPABASE_ANON_KEY=your_supabase_anon_key
# 或者使用 NEXT_PUBLIC_ 前缀
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI SDK配置 (coze-coding-dev-sdk)
COZE_API_KEY=your_coze_api_key

# 对象存储配置 (可选，用于文件上传)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=your_region
S3_BUCKET_NAME=your_bucket_name

# 应用配置
NEXT_PUBLIC_APP_URL=http://localhost:5000

# 安全配置
JWT_SECRET=your-jwt-secret-key-change-in-production
ADMIN_DEFAULT_PASSWORD=

# 默认教务老师账号（数据导入时自动创建）
# 格式：username1:name1,username2:name2
# 生产环境必须设置强密码 DEFAULT_ADMIN_PASSWORD
DEFAULT_ADMIN_TEACHERS=xinxin:心心,yanzi:燕子
DEFAULT_ADMIN_PASSWORD=

# 批量导入时 adminType 到教务老师用户名的映射
# 格式：type1:username1,type2:username2
ADMIN_TEACHER_MAPPINGS=心:心心,高:燕子

# PDF 页面图片配置（可选，不配置则使用默认素材）
# NEXT_PUBLIC_BG_IMAGE_URL=/images/pdf-bg.png
# NEXT_PUBLIC_LOGO_URL=/images/logo.png
